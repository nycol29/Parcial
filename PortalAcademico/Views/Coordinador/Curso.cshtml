@model IEnumerable<PortalAcademico.Models.Curso>
@{
    ViewData["Title"] = "Panel Coordinador - Cursos";
}

<h2>Panel Coordinador - Cursos</h2>

@if(TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<a asp-action="Create" class="btn btn-success mb-3">Crear Curso</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Créditos</th>
            <th>Cupo</th>
            <th>Activo</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach(var curso in Model)
    {
        <tr>
            <td>@curso.Codigo</td>
            <td>@curso.Nombre</td>
            <td>@curso.Creditos</td>
            <td>@curso.CupoMaximo</td>
            <td>@(curso.Activo ? "Sí" : "No")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@curso.Id" class="btn btn-primary btn-sm">Editar</a>
                <form asp-action="Desactivar" asp-route-id="@curso.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-warning btn-sm">Desactivar</button>
                </form>
                <a asp-action="Matriculas" asp-route-cursoId="@curso.Id" class="btn btn-info btn-sm">Matrículas</a>
            </td>
        </tr>
    }
    </tbody>
</table>
